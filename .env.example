# MongoDB (local: mongodb://127.0.0.1:27017/feedback_poc — Docker Compose: mongodb://mongo:27017/feedback_poc)
MONGODB_URI=mongodb://127.0.0.1:27017/feedback_poc

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (OAuth redirect base). Local: http://localhost:3000
AUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client)
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth (GitHub → Settings → Developer settings → OAuth Apps)
# Authorization callback URL: {AUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# LLM — bring your own (server-side only)
# Provider picks the API adapter: openai | anthropic (alias: claude)
LLM_PROVIDER=anthropic
LLM_API_KEY=
# Optional; if empty, defaults are gpt-4o-mini (openai) or claude-3-5-haiku-20241022 (anthropic)
# LLM_MODEL=gpt-4o-mini
LLM_MODEL=claude-3-5-haiku-20241022

# Optional: Bearer secret for POST /api/feedback without a browser session (agents, webhooks)
FEEDBACK_INGEST_API_KEY=

# Health: GET /api/health (add ?mongo=1 to verify MongoDB — no env key required)
