{
  "name": "feedback_app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vinext dev --port 3000 --hostname 0.0.0.0",
    "build": "vinext build",
    "start": "vinext start --hostname 0.0.0.0",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "mongo": "docker compose up -d mongo",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f web",
    "deps:update": "npx npm-check-updates",
    "dev:next": "next dev",
    "build:next": "next build",
    "start:next": "next start"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-rsc": "^0.5.21",
    "mongoose": "^9.3.3",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-server-dom-webpack": "^19.2.4",
    "vinext": "^0.0.39",
    "vite": "^8.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.2",
